[Unit]
Description=Plane PostgreSQL database
After=exousia-network.service
Requires=exousia-network.service

[Container]
Image=docker.io/library/postgres:15.7-alpine
ContainerName=plane-db
Exec=postgres -c max_connections=1000
Volume=plane-db-data.volume:/var/lib/postgresql/data
Network=exousia.network
PodmanArgs=--env-file=/etc/exousia/plane/plane.env
Label=io.containers.autoupdate=registry

[Service]
Restart=always
TimeoutStartSec=300

[Install]
WantedBy=default.target
