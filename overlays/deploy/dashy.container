[Unit]
Description=Dashy dashboard

[Container]
Image=ghcr.io/lissy93/dashy:latest
ContainerName=dashy
Network=exousia.network:alias=dashy
PublishPort=127.0.0.1:3030:8080
Volume=%h/.config/dashy:/app/user-data:z
Label=io.containers.autoupdate=registry

HealthCmd=wget -q -O /dev/null http://127.0.0.1:8080/ || exit 1
HealthInterval=30s
HealthTimeout=5s
HealthRetries=3
HealthStartPeriod=15s

[Service]
Restart=always
TimeoutStartSec=120

[Install]
WantedBy=default.target
