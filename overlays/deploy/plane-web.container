[Unit]
Description=Plane web frontend
After=plane-api.service plane-worker.service
Requires=plane-api.service plane-worker.service

[Container]
Image=docker.io/makeplane/plane-frontend:stable
ContainerName=plane-web
Network=exousia.network:alias=web
PodmanArgs=--env-file=/etc/exousia/plane/plane.env
Label=io.containers.autoupdate=registry

[Service]
Restart=always
TimeoutStartSec=180

# [Install]
# WantedBy=default.target
