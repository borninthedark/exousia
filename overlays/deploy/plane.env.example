# Base URLs exposed through the local proxy.
WEB_URL=http://localhost:8080
ADMIN_BASE_URL=http://localhost:8080/god-mode
SPACE_BASE_URL=http://localhost:8080/spaces
APP_BASE_URL=http://localhost:8080
CORS_ALLOWED_ORIGINS=http://localhost:8080,http://localhost:3000

# Core application settings.
DEBUG=0
SECRET_KEY=change-me-before-sharing-this-instance
FILE_SIZE_LIMIT=5242880
GUNICORN_WORKERS=3

# Internal service wiring.
DATABASE_URL=postgresql://plane:plane@plane-db:5432/plane
REDIS_URL=redis://plane-redis:6379/
AMQP_URL=amqp://plane:plane@plane-mq:5672/%2f

# Embedded data services.
POSTGRES_USER=plane
POSTGRES_PASSWORD=plane
POSTGRES_DB=plane
RABBITMQ_DEFAULT_USER=plane
RABBITMQ_DEFAULT_PASS=plane
RABBITMQ_DEFAULT_VHOST=/
MINIO_ROOT_USER=plane
MINIO_ROOT_PASSWORD=change-me-minio

# Object storage defaults for the bundled MinIO service.
USE_MINIO=1
MINIO_ENDPOINT_SSL=0
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=plane
AWS_SECRET_ACCESS_KEY=change-me-minio
AWS_S3_ENDPOINT_URL=http://plane-minio:9000
AWS_S3_BUCKET_NAME=uploads

# Exousia-specific note:
# Plane shares exousia.network with Forgejo. Use http://forgejo:3000 inside
# the Quadlet network when configuring Plane SCM integrations for this repo.
