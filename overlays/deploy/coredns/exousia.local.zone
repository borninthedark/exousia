$ORIGIN exousia.local.
$TTL 60

@       IN SOA  ns.exousia.local. admin.exousia.local. (
            2026050301 ; serial
            3600       ; refresh
            600        ; retry
            86400      ; expire
            60         ; minimum TTL
        )

        IN NS   ns.exousia.local.

ns      IN A    127.0.0.1

; Wildcard — all *.exousia.local resolves to loopback.
; New apps need only a Caddyfile entry, no DNS change.
*       IN A    127.0.0.1
