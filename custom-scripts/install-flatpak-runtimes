#!/bin/bash
# Install only flatpak runtimes at build time
# This reduces app installation time later without bloating the image with apps
# Apps can be installed quickly on first boot since runtimes are already present

set -euo pipefail

log() {
    echo "[install-flatpak-runtimes] $*"
}

error() {
    echo "[ERROR] $*" >&2
}

main() {
    log "Installing flatpak runtimes at build time"

    # Ensure flathub remote exists
    if ! flatpak remote-list | grep -q flathub; then
        error "Flathub remote not configured"
        exit 1
    fi

    # List of essential runtimes to pre-install
    # These are the base platforms that most apps depend on
    local runtimes=(
        "org.freedesktop.Platform//24.08"
        "org.freedesktop.Platform//25.08"
        "org.freedesktop.Sdk//24.08"
        "org.freedesktop.Sdk//25.08"
        "org.gnome.Platform//48"
        "org.gnome.Platform//49"
        "org.kde.Platform//5.15-24.08"
        "org.kde.Platform//6.8"
        "org.kde.Platform//6.9"
        "org.kde.Platform//6.10"
    )

    local installed=0
    local failed=0

    for runtime in "${runtimes[@]}"; do
        log "Installing runtime: $runtime"
        if flatpak install --assumeyes --noninteractive flathub "$runtime" 2>&1 | grep -v "^$"; then
            log "✓ Installed: $runtime"
            ((installed++))
        else
            error "✗ Failed: $runtime"
            ((failed++))
        fi
    done

    log "Runtime installation complete: $installed succeeded, $failed failed"

    # Show installed runtimes
    log "Installed runtimes:"
    flatpak list --runtime --columns=application,version

    if [[ $failed -gt 0 ]]; then
        log "Warning: $failed runtimes failed to install"
    fi

    log "Runtimes ready - apps can now install quickly"
}

main "$@"
