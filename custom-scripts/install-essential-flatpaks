#!/bin/bash
# Install essential flatpak applications at build time
# This includes a curated list of must-have apps that should be immediately available
# Runtimes are installed separately via install-flatpak-runtimes

set -euo pipefail

log() {
    echo "[install-essential-flatpaks] $*"
}

error() {
    echo "[ERROR] $*" >&2
}

main() {
    log "Installing essential flatpak applications at build time"

    # Ensure flathub remote exists
    if ! flatpak remote-list | grep -q flathub; then
        error "Flathub remote not configured"
        exit 1
    fi

    # Essential applications to install at build time
    # Keep this list small to avoid bloating the image
    # Full list of apps can be installed on first boot
    local apps=(
        "org.mozilla.firefox//stable"
        "com.github.tchx84.Flatseal//stable"
        "org.kde.kate//stable"
    )

    local installed=0
    local failed=0

    for app in "${apps[@]}"; do
        log "Installing app: $app"
        if flatpak install --assumeyes --noninteractive flathub "$app" 2>&1 | grep -v "^$"; then
            log "✓ Installed: $app"
            ((installed++))
        else
            error "✗ Failed: $app"
            ((failed++))
            # Don't fail build for app installation failures
        fi
    done

    log "Essential app installation complete: $installed succeeded, $failed failed"

    # Show installed apps
    log "Installed applications:"
    flatpak list --app --columns=application,version

    log "Essential apps ready"
}

main "$@"
